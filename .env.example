# Persistent browser profile directory (Linux VPS: /profiles/main)
PROFILE_DIR=./profiles/main

# Optional: path to store list (default ./stores/stores.json)
# STORES_PATH=./stores/stores.json

# Google Sheets — pick ONE:
# A) Service account (recommended on VPS)
# SPREADSHEET_ID=optional_if_every_store_has_spreadsheetId
# GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/service-account.json

# B) OAuth (legacy Shopify scraper): copy credentials.json + token.json into project root
# GOOGLE_OAUTH_CREDENTIALS=./credentials.json
# GOOGLE_OAUTH_TOKEN=./token.json

# Optional default sheet when a store omits spreadsheetId
SPREADSHEET_ID=

# Match legacy scraper "yesterday" (India)
SHEET_DATE_TZ=Asia/Kolkata

# Extra wait after analytics table loads (legacy mode default 9000 if unset)
# LEGACY_POST_LOAD_DELAY_MS=9000

# Date search only reads column A from row 1..N (not entire A:A — huge sheets were hanging)
# SHEET_DATE_MAX_ROWS=8000

# Google Sheets API request timeout (ms)
# SHEETS_API_TIMEOUT_MS=120000

# 1 = show Chrome during `npm run run` and `check-session`. Use 0 or unset on VPS/cron (headless).
HEADFUL_RUN=0

# Same as above, without editing .env:
# npm run run:headed

# Optional: default sheet tab if a store omits sheetTab
DEFAULT_SHEET_TAB=Sheet1

# Date column in sheet for matching rows (default A)
DATE_COLUMN=A

# Metric columns (default K, L, M = Sessions, Add to Cart, Reached Checkout)
COL_SESSIONS=K
COL_ADD_TO_CART=L
COL_REACHED_CHECKOUT=M

# Target date YYYY-MM-DD (omit for yesterday in server local time)
# TARGET_DATE=2025-03-18

# Server timezone (recommended on VPS)
# TZ=America/Denver

# Login often fails on bundled Chromium (stuck after email). Use real Chrome:
PLAYWRIGHT_CHANNEL=chrome

# Linux VPS only: if Chromium exits with SIGTRAP right after launch, add space-separated flags:
# PLAYWRIGHT_CHROMIUM_ARGS=--disable-gpu --disable-software-rasterizer --disable-crash-reporter

# Linux headful (Xvfb): code auto-strips Playwright's --enable-unsafe-swiftshader and adds ozone/x11 + GPU-off flags.
# Set to 0 only if you need to opt out of those extras:
# PLAYWRIGHT_LINUX_HEADFUL_EXTRA=0

# Headless mode variant:
# - omit or any value: regular headless
# - HEADLESS_MODE=shell: chromium-headless-shell (sometimes less detectable)
HEADLESS_MODE=

# Where to open for `npm run login` (optional)
# LOGIN_START_URL=https://accounts.shopify.com/lookup
